}

function normSourceTable(raw, index, fallbackMaxRows) {
    var src = raw || {};
    var sourceColumns = (src.columns && typeof src.columns.length === "number") ? src.columns : [];
    var columns = [];
    for (var i = 0; i < sourceColumns.length; i += 1)
        columns.push(normSourceColumn(sourceColumns[i], i));
    if (!columns.length)
        columns.push(normSourceColumn({}, 0));
    return {
        key: normalizeKey(src.key || ("table_" + String(index + 1))),
        label: safeString(src.label || ("Table " + String(index + 1))).trim(),
        sheet: safeString(src.sheet || "Sheet1").trim(),
        headerRow: Math.max(1, toInt(src.headerRow, 1)),
        startRowOffset: Math.max(0, toInt(src.startRowOffset, 1)),
        keyHeader: safeString(src.keyHeader || "").trim(),
        emptyRowTolerance: Math.max(0, toInt(src.emptyRowTolerance, 1)),
        maxRows: Math.max(1, toInt(src.maxRows, fallbackMaxRows)),
        columns: columns,
        required: !(src && src.required === false)
    };
}

function buildHeaderMap(sheet, headerRow, scanColumns) {
    var map = {};
    for (var col = 1; col <= scanColumns; col += 1) {
        var text = readCell(sheet, numberToCol(col) + String(headerRow), "text").displayValue;
        var key = normalizeKey(text);
        if (key && map[key] === undefined)
            map[key] = col;
    }
    return map;
}

function collectSourceLists(schemaLists, strictMode, fallbackMaxRows, result) {
    for (var i = 0; i < schemaLists.length; i += 1) {
        var list = normSourceList(schemaLists[i], i, fallbackMaxRows);
        var listSheet = getSheetOrNull(list.sheet);
        if (!listSheet) {
            if (list.required || strictMode)
                throw new Error("Sheet not found: " + list.sheet + " for list \"" + list.label + "\".");
            continue;
        }
        var startCell = parseA1Cell(list.startAddress);
        if (!startCell)
            throw new Error("Invalid start cell: \"" + list.startAddress + "\" for list \"" + list.label + "\".");
        var stopToken = normalizeKey(list.stopValue);
        var items = [];
        for (var offset = 0; offset < list.maxItems; offset += 1) {
            var col = startCell.col + (list.direction === "right" ? offset : 0);
            var row = startCell.row + (list.direction === "down" ? offset : 0);
            var addr = numberToCol(col) + String(row);
            var listCell = readCell(listSheet, addr, list.type);
            var displayValue = safeString(listCell.displayValue).trim();
            if (list.stopMode === "stop_value") {
                if (!displayValue)
                    break;
                if (stopToken && normalizeKey(displayValue) === stopToken)
                    break;
            } else if (!isFilled(listCell.value, list.type)) {
                break;
            }
            items.push(listCell.value);
        }
        if (list.required && !items.length)
            throw new Error("List \"" + list.label + "\" has no data.");
        result.lists[list.key] = {
            key: list.key,
            label: list.label,
            type: list.type,
            items: items
        };
    }
}

function collectSourceData() {
    var result = { fields: {}, lists: {}, tables: {} };
    var schemaFields = (sourceSchema.fields && typeof sourceSchema.fields.length === "number") ? sourceSchema.fields : [];
    var schemaLists = (sourceSchema.lists && typeof sourceSchema.lists.length === "number") ? sourceSchema.lists : [];
    var schemaTables = (sourceSchema.tables && typeof sourceSchema.tables.length === "number") ? sourceSchema.tables : [];
    var strictMode = !(sourceFileConfig && sourceFileConfig.strictMode === false);
    var fallbackMaxRows = Math.max(1, toInt(sourceFileConfig.maxRowsDefault, 200));

    for (var i = 0; i < schemaFields.length; i += 1) {
        var field = normSourceField(schemaFields[i], i);
        var fieldSheet = getSheetOrNull(field.sheet);
        if (!fieldSheet) {
            if (field.required || strictMode)
                throw new Error("Sheet not found: " + field.sheet + " for field \"" + field.label + "\".");
            continue;
        }
        var fieldCell = readCell(fieldSheet, field.address, field.type);
        if (field.required && !isFilled(fieldCell.value, field.type))
            throw new Error("Required field is empty: \"" + field.label + "\".");
        result.fields[field.key] = {
            key: field.key,
            label: field.label,
            type: field.type,
            value: fieldCell.value,
            displayValue: fieldCell.displayValue
        };
    }

    collectSourceLists(schemaLists, strictMode, fallbackMaxRows, result);

    for (var t = 0; t < schemaTables.length; t += 1) {
        var table = normSourceTable(schemaTables[t], t, fallbackMaxRows);
        var tableSheet = getSheetOrNull(table.sheet);
        if (!tableSheet) {
            if (table.required || strictMode)
                throw new Error("Sheet not found: " + table.sheet + " for table \"" + table.label + "\".");
            continue;
        }
        var scanColumns = Math.max(64, table.columns.length * 8, colToNumber("CZ"));
        var headerMap = buildHeaderMap(tableSheet, table.headerRow, scanColumns);
        var keyColumn = headerMap[normalizeKey(table.keyHeader)];
        if (!keyColumn)
            throw new Error("Key column not found: \"" + table.keyHeader + "\" in table \"" + table.label + "\".");
        var resolvedColumns = [];
        for (var c = 0; c < table.columns.length; c += 1) {
            var column = table.columns[c];
            var headerIndex = headerMap[normalizeKey(column.header)];
            if (!headerIndex && column.required)
                throw new Error("Column not found: \"" + column.header + "\" in table \"" + table.label + "\".");
            resolvedColumns.push({
                key: column.key,
                label: column.label,
                type: column.type,
                colIndex: headerIndex || 0
            });
        }
        var startRow = table.headerRow + table.startRowOffset;
        var rows = [];
        var emptyStreak = 0;
        for (var rowOffset = 0; rowOffset < table.maxRows; rowOffset += 1) {
            var rowNumber = startRow + rowOffset;
            var keyCell = readCell(tableSheet, numberToCol(keyColumn) + String(rowNumber), "text");
            if (!isFilled(keyCell.value, "text")) {
                emptyStreak += 1;
                if (emptyStreak > table.emptyRowTolerance)
                    break;
                continue;
            }
            emptyStreak = 0;
            var row = {};
            for (var rc = 0; rc < resolvedColumns.length; rc += 1) {
                var resolved = resolvedColumns[rc];
                var dataCell = resolved.colIndex ? readCell(tableSheet, numberToCol(resolved.colIndex) + String(rowNumber), resolved.type) : { value: "", displayValue: "" };
                row[resolved.key] = dataCell.value;
            }
            rows.push(row);
        }
        if (table.required && !rows.length)
            throw new Error("Table \"" + table.label + "\" has no data.");
        result.tables[table.key] = {
            key: table.key,
            label: table.label,
            columns: resolvedColumns,
            rows: rows
        };
    }
    return result;
}

function requireSourceField(key) {
    var id = normalizeKey(key);
    if (!id || !sourceData.fields[id])
        throw new Error("Source field not found: \"" + safeString(key) + "\".");
    return sourceData.fields[id];
}

function requireSourceList(key) {
    var id = normalizeKey(key);
    if (!id || !sourceData.lists[id])
        throw new Error("Source list not found: \"" + safeString(key) + "\".");
    return sourceData.lists[id];
}

function requireSourceTable(key) {
    var id = normalizeKey(key);
    if (!id || !sourceData.tables[id])
        throw new Error("Source table not found: \"" + safeString(key) + "\".");
    return sourceData.tables[id];
}

function copyTemplateRowStyle(fromSheet, toSheet, templateRangeRaw, targetCellRaw) {
    var templateRange = parseA1Range(templateRangeRaw);
    var targetCell = parseA1Cell(targetCellRaw);
    var targetRange;
    var targetA1 = "";
    var offset = 0;
    var srcCell;
    var dstCell;
    var formula = "";
    var value = "";
    if (!templateRange)
        throw new Error("Invalid template row: " + safeString(templateRangeRaw));
    if (templateRange.r1 !== templateRange.r2)
        throw new Error("Template row must be a single-row range.");
    if (!targetCell)
        throw new Error("Invalid target cell: " + safeString(targetCellRaw));
    targetRange = {
        c1: targetCell.col,
        c2: targetCell.col + (templateRange.c2 - templateRange.c1),
        r1: targetCell.row,
        r2: targetCell.row
    };
    rangeOn(fromSheet, formatA1Range(templateRange)).Copy();
    rangeOn(toSheet, numberToCol(targetRange.c1) + String(targetRange.r1)).PasteSpecial("xlPasteAll", "xlPasteSpecialOperationNone", false, false);
    targetA1 = formatA1Range(targetRange);
    for (offset = 0; offset <= (templateRange.c2 - templateRange.c1); offset += 1) {
        srcCell = rangeOn(fromSheet, numberToCol(templateRange.c1 + offset) + String(templateRange.r1));
        dstCell = rangeOn(toSheet, numberToCol(targetRange.c1 + offset) + String(targetRange.r1));
        formula = "";
        value = "";
        try {
            formula = safeString(srcCell.GetFormula()).trim();
        } catch (eFormula) {
            formula = "";
        }
        if (formula && formula.charAt(0) === "=") {
            dstCell.SetValue(formula);
            continue;
        }
        try {
            value = srcCell.GetValue();
        } catch (eValue) {
            value = "";
        }
        dstCell.SetValue(value);
    }
    // DocumentBuilder paste keeps fill/font but may drop side/bottom borders on inserted rows.
    // Re-apply a standard tabular border set so duplicated template rows stay visually intact.
    applyBorders(rangeOn(toSheet, targetA1), "all", "Thin", "#000000");
}

function applySetCellValueAction(action, forcedValue, forcedMode) {
    var sh = sheetByRef(action.sheet);
    var rng = rangeOn(sh, action.range || "A1", action.named_range);
    var mode = String((forcedMode === undefined || forcedMode === null) ? (action.mode || "text") : forcedMode).toLowerCase();
    var value = (forcedValue === undefined) ? action.value : forcedValue;
    if (mode === "number") {
        var num = Number(value);
        value = isNaN(num) ? 0 : num;
    } else if (mode === "bool") {
        value = toBool(value, false);
    } else if (mode === "formula") {
        value = String(value || "");
        if (value && value.charAt(0) !== "=")
            value = "=" + value;
    } else {
        value = (value === undefined || value === null) ? "" : String(value);
    }
    rng.SetValue(value);
    if (toBool(action.merge, false))
        rng.Merge(false);
    var hasKeepFlag = !(action.keep_template_format === undefined || action.keep_template_format === null || String(action.keep_template_format).trim() === "");
    var hasLegacyApply = !(action.apply_style === undefined || action.apply_style === null);
    var legacyApply = toBool(action.apply_style, false);
    var applyAlignment = toBool(action.apply_alignment, hasLegacyApply ? legacyApply : false);
    var applyNumberFormat = toBool(action.apply_number_format, false);
    var applyFont = toBool(action.apply_font, false);
    var applyFill = toBool(action.apply_fill, false);
    var keepTemplate = hasKeepFlag ? toBool(action.keep_template_format, true) : !(applyAlignment || applyNumberFormat || applyFont || applyFill || legacyApply);
    if (keepTemplate)
        return;
    if (applyAlignment) {
        var insH = String(action.horizontal || "").trim().toLowerCase();
        var insV = String(action.vertical || "").trim().toLowerCase();
        if (insH)
            rng.SetAlignHorizontal(insH);
        if (insV)
            rng.SetAlignVertical(insV);
        rng.SetWrap(toBool(action.wrap, false));
    }
    if (applyNumberFormat) {
        var insFmt = buildNumberFormat(action);
        rng.SetNumberFormat(insFmt);
    }
    if (applyFont) {
        var insFontName = String(action.font_name || "").trim();
        var insFontSize = toNumber(action.font_size, NaN);
        if (insFontName)
            rng.SetFontName(insFontName);
        if (!isNaN(insFontSize) && insFontSize > 0)
            rng.SetFontSize(insFontSize);
        rng.SetBold(toBool(action.bold, false));
        rng.SetItalic(toBool(action.italic, false));
        rng.SetUnderline(normalizeUnderline(action.underline));
        rng.SetStrikeout(toBool(action.strikeout, false));
        var insFontColorRaw = String(action.font_color === undefined || action.font_color === null ? "" : action.font_color).trim().toLowerCase();
        if (insFontColorRaw && insFontColorRaw !== "auto")
            rng.SetFontColor(colorFromHex(action.font_color));
    }
    if (applyFill) {
        if (isNoFill(action.fill_color))
            rng.SetFillColor("No Fill");
        else
            rng.SetFillColor(colorFromHex(action.fill_color));
    }
}

var sourceData = { fields: {}, lists: {}, tables: {} };

function executeAction(action) {
    var type = String(action.type || "");
    if (!type)
        return;

    if (type === "set_cell_value") {
        applySetCellValueAction(action);
        return;
    }

    if (type === "clear_range") {
        var shClear = sheetByRef(action.sheet);
        var rgClear = rangeOn(shClear, action.range || "A1");
        var clearMode = String(action.mode || "contents");
        if (clearMode === "formats")
            rgClear.ClearFormats();
        else if (clearMode === "hyperlinks")
            rgClear.ClearHyperlinks();
        else if (clearMode === "all")
            rgClear.Clear();
        else
            rgClear.ClearContents();
        return;
    }

    if (type === "formula_to_value") {
        var shFormula = sheetByRef(action.sheet);
        var rgFormula = rangeOn(shFormula, action.range || "A1");
        rgFormula.ForEach(function (cell) {
            var f = cell.GetFormula();
            if (f && String(f).trim() !== "") {
                var v = cell.GetValue();
                cell.SetValue(v);
            }
        });
        return;
    }

    if (type === "set_border") {
        var shBorder = sheetByRef(action.sheet);
        var rgBorder = rangeOn(shBorder, action.range || "A1");
        applyBorders(rgBorder, String(action.scope || "all"), String(action.style || "Thin"), action.color || "#000000");
        return;
    }

    if (type === "set_font_style") {
        var shFont = sheetByRef(action.sheet);
        var rgFont = rangeOn(shFont, action.range || "A1");
        var fontName = String(action.font_name || "").trim();
        var fontSize = toNumber(action.font_size, NaN);
        if (fontName)
            rgFont.SetFontName(fontName);
        if (!isNaN(fontSize) && fontSize > 0)
            rgFont.SetFontSize(fontSize);
        rgFont.SetBold(toBool(action.bold, false));
        rgFont.SetItalic(toBool(action.italic, false));
        rgFont.SetUnderline(normalizeUnderline(action.underline));
        rgFont.SetStrikeout(toBool(action.strikeout, false));
        var fontColorRaw = String(action.font_color === undefined || action.font_color === null ? "" : action.font_color).trim().toLowerCase();
        if (fontColorRaw && fontColorRaw !== "auto")
            rgFont.SetFontColor(colorFromHex(action.font_color));
        return;
    }

    if (type === "set_fill_color") {
        var shFill = sheetByRef(action.sheet);
        var rgFill = rangeOn(shFill, action.range || "A1");
        if (isNoFill(action.color))
            rgFill.SetFillColor("No Fill");
        else
            rgFill.SetFillColor(colorFromHex(action.color));
        return;
    }

    if (type === "set_number_format") {
        var shFmt = sheetByRef(action.sheet);
        var rgFmt = rangeOn(shFmt, action.range || "A1");
        var fmt = buildNumberFormat(action);
        rgFmt.SetNumberFormat(fmt);
        return;
    }

    if (type === "set_alignment") {
        var shAlign = sheetByRef(action.sheet);
        var rgAlign = rangeOn(shAlign, action.range || "A1");
        var h = String(action.horizontal || "").trim().toLowerCase();
        var v = String(action.vertical || "").trim().toLowerCase();
        var ro = String(action.reading_order || "").trim().toLowerCase();
        var ori = normalizeOrientation(action.orientation);
        if (h)
            rgAlign.SetAlignHorizontal(h);
        if (v)
            rgAlign.SetAlignVertical(v);
        rgAlign.SetWrap(toBool(action.wrap, false));
        if (ori !== null)
            rgAlign.SetOrientation(ori);
        if (ro === "context" || ro === "ltr" || ro === "rtl")
            rgAlign.SetReadingOrder(ro);
        return;
    }

    if (type === "merge_range") {
        var shMerge = sheetByRef(action.sheet);
        rangeOn(shMerge, action.range || "A1").Merge(toBool(action.across, false));
        return;
    }

    if (type === "unmerge_range") {
        var shUnmerge = sheetByRef(action.sheet);
        rangeOn(shUnmerge, action.range || "A1").UnMerge();
        return;
    }

    if (type === "insert_rows") {
        var shInsRows = sheetByRef(action.sheet);
        rangeOn(shInsRows, rowSpan(action.start_row, action.count)).Insert("down");
        return;
    }

    if (type === "delete_rows") {
        var shDelRows = sheetByRef(action.sheet);
        rangeOn(shDelRows, rowSpan(action.start_row, action.count)).Delete("up");
        return;
    }

    if (type === "set_rows_hidden") {
        var shRows = sheetByRef(action.sheet);
        var r1 = Math.max(1, toInt(action.start_row, 1));
        var r2 = Math.max(r1, toInt(action.end_row, r1));
        rangeOn(shRows, String(r1) + ":" + String(r2)).SetHidden(toBool(action.hidden, true));
        return;
    }

    if (type === "insert_columns") {
        var shInsCols = sheetByRef(action.sheet);
        rangeOn(shInsCols, colSpan(action.start_column, action.count)).Insert("right");
        return;
    }

    if (type === "delete_columns") {
        var shDelCols = sheetByRef(action.sheet);
        rangeOn(shDelCols, colSpan(action.start_column, action.count)).Delete("left");
        return;
    }

    if (type === "set_columns_hidden") {
        var shCols = sheetByRef(action.sheet);
        var c1 = numberToCol(colToNumber(action.start_column));
        var c2 = numberToCol(Math.max(colToNumber(action.start_column), colToNumber(action.end_column)));
        rangeOn(shCols, c1 + ":" + c2).SetHidden(toBool(action.hidden, true));
        return;
    }

    if (type === "group_rows") {
        var shGroupRows = sheetByRef(action.sheet);
        var gr1 = Math.max(1, toInt(action.start_row, 1));
        var gr2 = Math.max(gr1, toInt(action.end_row, gr1));
        var rowsRange = String(gr1) + ":" + String(gr2);
        if (!groupSelection(shGroupRows, rowsRange, true, action.collapsed))
            rangeOn(shGroupRows, rowsRange).SetHidden(toBool(action.collapsed, false));
        return;
    }

    if (type === "group_columns") {
        var shGroupCols = sheetByRef(action.sheet);
        var gc1 = numberToCol(colToNumber(action.start_column));
        var gc2 = numberToCol(Math.max(colToNumber(action.start_column), colToNumber(action.end_column)));
        var colsRange = gc1 + ":" + gc2;
        if (!groupSelection(shGroupCols, colsRange, false, action.collapsed))
            rangeOn(shGroupCols, colsRange).SetHidden(toBool(action.collapsed, false));
        return;
    }

    if (type === "autofit") {
        var shAutofit = sheetByRef(action.sheet);
        rangeOn(shAutofit, action.range || "A:Z").AutoFit(toBool(action.rows, true), toBool(action.cols, true));
        return;
    }

    if (type === "set_row_height") {
        var shRowH = sheetByRef(action.sheet);
        var rgRowH = rangeOn(shRowH, action.range || "1:1");
        var rowH = toNumber(action.height, NaN);
        if (!isNaN(rowH) && rowH > 0)
            rgRowH.SetRowHeight(rowH);
        return;
    }

    if (type === "set_column_width") {
        var shColW = sheetByRef(action.sheet);
        var rgColW = rangeOn(shColW, action.range || "A:A");
        var colW = toNumber(action.width, NaN);
        if (!isNaN(colW) && colW > 0)
            rgColW.SetColumnWidth(colW);
        return;
    }

    if (type === "copy_paste_range") {
        var shFrom = sheetByRef(action.from_sheet);
        var shTo = sheetByRef(action.to_sheet === undefined || action.to_sheet === null || action.to_sheet === "" ? action.from_sheet : action.to_sheet);
        var rgFrom = rangeOn(shFrom, action.from_range || "A1");
        var rgTo = rangeOn(shTo, action.to_cell || "A1");
        var pasteType = String(action.paste_type || "xlPasteAll");
        var operation = String(action.operation || "xlPasteSpecialOperationNone");
        rgFrom.Copy();
        rgTo.PasteSpecial(pasteType, operation, toBool(action.skip_blanks, false), toBool(action.transpose, false));
        return;
    }

    if (type === "copy_template_row") {
        var shTemplateFrom = sheetByRef(action.from_sheet);
        var shTemplateTo = sheetByRef(action.to_sheet === undefined || action.to_sheet === null || action.to_sheet === "" ? action.from_sheet : action.to_sheet);
        copyTemplateRowStyle(shTemplateFrom, shTemplateTo, action.from_range || "A1:A1", action.to_cell || "A1");
        return;
    }

    if (type === "sort_range") {
        var shSort = sheetByRef(action.sheet);
        var rgSort = rangeOn(shSort, action.range || "A1");
        var key1 = sortKeyRange(shSort, action.key1);
        if (!key1)
            return;
        var key2 = sortKeyRange(shSort, action.key2);
        var key3 = sortKeyRange(shSort, action.key3);
        var sortOrientation = String(action.sort_by || "rows").toLowerCase() === "columns" ? "xlSortColumns" : "xlSortRows";
        var header = toBool(action.header, true) ? "xlYes" : "xlNo";
        rgSort.SetSort(key1, sortOrder(action.order1), key2, sortOrder(action.order2), key3, sortOrder(action.order3), header, sortOrientation);
        return;
    }

    if (type === "set_autofilter") {
        var shFilter = sheetByRef(action.sheet);
        var rgFilter = rangeOn(shFilter, action.range || "A1");
        var rawField = action.field;
        var hasField = !(rawField === undefined || rawField === null || String(rawField).trim() === "");
        if (!hasField) {
            rgFilter.SetAutoFilter();
            return;
        }
        var field = Math.max(1, toInt(rawField, 1));
        var opRaw = String(action.operator || "").trim();
        var op = opRaw ? opRaw : undefined;
        var c1 = criteriaValue(action.criteria1, opRaw);
        var c2 = (action.criteria2 === undefined || action.criteria2 === null || String(action.criteria2).trim() === "") ? undefined : String(action.criteria2).trim();
        rgFilter.SetAutoFilter(field, c1, op, c2, toBool(action.visible_drop_down, true));
        return;
    }

    if (type === "set_array_formula") {
        var shArr = sheetByRef(action.sheet);
        var rgArr = rangeOn(shArr, action.range || "A1");
        var formula = String(action.formula || "").trim();
        if (!formula)
            return;
        if (formula.charAt(0) !== "=")
            formula = "=" + formula;
        rgArr.SetFormulaArray(formula);
        return;
    }

    if (type === "set_gridlines") {
        var shGrid = sheetByRef(action.sheet);
        shGrid.SetDisplayGridlines(toBool(action.show, true));
        return;
    }

    if (type === "replace_token") {
        var token = String(action.token === undefined || action.token === null ? "" : action.token);
        if (!token)
            return;
        var replacement = String(action.value === undefined || action.value === null ? "" : action.value);
        var targets = sheetsForScope(action.scope, action.sheets);
        for (var si = 0; si < targets.length; si += 1)
            replaceTokenOnSheet(targets[si], token, replacement);
        return;
    }

    if (type === "insert_source_field") {
        var sourceField = requireSourceField(action.source_field_id);
        var targets = parseTargetBindings(action.targets);
        if (!targets.length) {
            targets.push({
                sheet: safeString(action.sheet || "Sheet1").trim() || "Sheet1",
                range: safeString(action.range || "A1").trim() || "A1"
            });
        }
        for (var ti = 0; ti < targets.length; ti += 1) {
            applySetCellValueAction({
                sheet: targets[ti].sheet,
                range: targets[ti].range,
                named_range: false,
                merge: false,
                keep_template_format: action.keep_template_format
            }, sourceField.value, sourceValueMode(sourceField.type, sourceField.value));
        }
        return;
    }

    if (type === "insert_source_list") {
        var sourceList = requireSourceList(action.source_list_id);
        var listTargets = parseSourceTableTargets(action.targets);
        if (!listTargets.length) {
            listTargets.push({
                sheet: safeString(action.sheet || "Sheet1").trim() || "Sheet1",
                anchorCell: safeString(action.anchor_cell || "A1").trim() || "A1",
                templateRowRange: safeString(action.template_row_range || "A1:D1").trim() || "A1:D1"
            });
        }
        var resolvedListTargets = [];
        for (var lti = 0; lti < listTargets.length; lti += 1) {
            var listTarget = listTargets[lti];
            var listAnchor = parseA1Cell(listTarget.anchorCell);
            if (!listAnchor)
                throw new Error("Invalid row anchor cell: " + safeString(listTarget.anchorCell));
            resolvedListTargets.push({
                order: lti,
                sheet: listTarget.sheet,
                anchor: listAnchor,
                templateRowRange: listTarget.templateRowRange
            });
        }
        var listInsertMode = safeString(action.insert_mode || "insert_rows").trim().toLowerCase();
        if (listInsertMode === "insert_rows" && resolvedListTargets.length > 1) {
            resolvedListTargets.sort(function (left, right) {
                if (left.sheet === right.sheet)
                    return right.anchor.row - left.anchor.row;
                return left.order - right.order;
            });
        }
        for (var targetIndex = 0; targetIndex < resolvedListTargets.length; targetIndex += 1) {
            var listTargetSpec = resolvedListTargets[targetIndex];
            var listTargetSheet = sheetByRef(listTargetSpec.sheet);
            for (var itemIndex = 0; itemIndex < sourceList.items.length; itemIndex += 1) {
                var targetRow = listTargetSpec.anchor.row + itemIndex;
                if (listInsertMode === "insert_rows" && itemIndex > 0)
                    rangeOn(listTargetSheet, String(targetRow) + ":" + String(targetRow)).Insert("down");
                if (toBool(action.keep_template_format, true) && (itemIndex > 0 || listInsertMode !== "insert_rows"))
                    copyTemplateRowStyle(listTargetSheet, listTargetSpec.templateRowRange, targetRow);
                var itemValue = sourceList.items[itemIndex];
                applySetCellValueAction({
                    sheet: listTargetSpec.sheet,
                    range: numberToCol(listTargetSpec.anchor.col) + String(targetRow),
                    named_range: false,
                    merge: false,
                    keep_template_format: action.keep_template_format
                }, itemValue, sourceValueMode(sourceList.type, itemValue));
            }
        }
        return;
    }

    if (type === "insert_source_table") {
        var sourceTable = requireSourceTable(action.source_table_id);
        var mappings = parseSourceMappings(action.mappings);
        if (!mappings.length)
            throw new Error("Column mappings are required for source table.");
        var insertMode = safeString(action.insert_mode || "insert_rows").trim().toLowerCase();
        var targets = parseSourceTableTargets(action.targets);
        if (!targets.length) {
            targets.push({
                sheet: safeString(action.sheet || "Sheet1").trim() || "Sheet1",
                anchorCell: safeString(action.anchor_cell || "A1").trim() || "A1",
                templateRowRange: safeString(action.template_row_range || "A1:D1").trim() || "A1:D1"
            });
        }
        var resolvedTargets = [];
        for (var ti = 0; ti < targets.length; ti += 1) {
            var target = targets[ti];
            var anchor = parseA1Cell(target.anchorCell);
            if (!anchor)
                throw new Error("Invalid row anchor cell: " + safeString(target.anchorCell));
            resolvedTargets.push({
                order: ti,
                sheet: target.sheet,
                anchor: anchor,
                templateRowRange: target.templateRowRange
            });
        }
        if (insertMode === "insert_rows" && resolvedTargets.length > 1) {
            resolvedTargets.sort(function (left, right) {
                if (left.sheet === right.sheet)
                    return right.anchor.row - left.anchor.row;
                return left.order - right.order;
            });
        }
        for (var targetIndex = 0; targetIndex < resolvedTargets.length; targetIndex += 1) {
            var targetSpec = resolvedTargets[targetIndex];
            var targetSheet = sheetByRef(targetSpec.sheet);
            for (var rowIndex = 0; rowIndex < sourceTable.rows.length; rowIndex += 1) {
                var targetRow = targetSpec.anchor.row + rowIndex;
                if (insertMode === "insert_rows" && rowIndex > 0)
                    rangeOn(targetSheet, String(targetRow) + ":" + String(targetRow)).Insert("down");
                if (toBool(action.keep_template_format, true) && (rowIndex > 0 || insertMode !== "insert_rows"))
                    copyTemplateRowStyle(targetSheet, targetSpec.templateRowRange, targetRow);
                var rowData = sourceTable.rows[rowIndex];
                for (var m = 0; m < mappings.length; m += 1) {
                    var mapping = mappings[m];
                    var cellValue = rowData[mapping.sourceKey];
                    var typeHint = "text";
                    for (var ci = 0; ci < sourceTable.columns.length; ci += 1) {
                        if (sourceTable.columns[ci].key === mapping.sourceKey) {
                            typeHint = sourceTable.columns[ci].type;
                            break;
                        }
                    }
                    applySetCellValueAction({
                        sheet: targetSpec.sheet,
                        range: mapping.targetColumn + String(targetRow),
                        named_range: false,
                        merge: false,
                        keep_template_format: action.keep_template_format
                    }, cellValue, sourceValueMode(typeHint, cellValue));
                }
            }
        }
        return;
    }

    if (type === "add_sheet") {
        Api.AddSheet(String(action.sheet_name || "NewSheet"));
        return;
    }

    if (type === "rename_sheet") {
        var shRename = sheetByRef(action.sheet);
        shRename.SetName(String(action.new_name || "Sheet"));
        return;
    }

    if (type === "delete_sheet") {
        var shDelete = sheetByRef(action.sheet);
        shDelete.Delete();
        return;
    }
}

builder.OpenFile("__REPORTS_LITERAL_TEMPLATE_PATH__", "");
for (var i = 0; i < actions.length; i += 1) {
    try {
        executeAction(actions[i]);
    } catch (e) {
        if (stopOnError)
            throw e;
    }
}
builder.SaveFile("xlsx", "__REPORTS_LITERAL_OUTPUT_PATH__");
builder.CloseFile();

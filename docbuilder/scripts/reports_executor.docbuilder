function colToNumber(col) {
    var s = String(col || "A").toUpperCase().replace(/[^A-Z]/g, "");
    if (!s)
        return 1;
    var n = 0;
    for (var i = 0; i < s.length; i += 1)
        n = n * 26 + (s.charCodeAt(i) - 64);

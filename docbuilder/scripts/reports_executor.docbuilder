    return out;
}

function parseTargetBindings(raw) {
    var text = safeString(raw).trim();
    if (!text)
        return [];
    var chunks = text.split(/[;\n]+/);
    var items = [];
    for (var i = 0; i < chunks.length; i += 1) {
        var block = safeString(chunks[i]).trim();
        if (!block)
            continue;
        var sep = block.indexOf(":");
        if (sep <= 0) {
            var bang = block.indexOf("!");

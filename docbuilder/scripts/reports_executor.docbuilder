}

function normSourceList(raw, index, fallbackMaxRows) {
    var src = raw || {};
    var type = safeString(src.type || "text").trim().toLowerCase();
    if (type !== "number" && type !== "date")
        type = "text";
    var direction = safeString(src.direction || "down").trim().toLowerCase();
    if (direction !== "right")
        direction = "down";
    var stopMode = safeString(src.stopMode || "empty").trim().toLowerCase();
    if (stopMode !== "stop_value")
        stopMode = "empty";
    return {
        key: normalizeKey(src.key || ("list_" + String(index + 1))),
        label: safeString(src.label || ("List " + String(index + 1))).trim(),
        sheet: safeString(src.sheet || "Sheet1").trim(),
        startAddress: safeString(src.startAddress || src.address || "A1").trim(),
        direction: direction,
        stopMode: stopMode,
        stopValue: safeString(src.stopValue || "").trim(),
        maxItems: Math.max(1, toInt(src.maxItems, fallbackMaxRows)),
        type: type,
        required: !(src && src.required === false)
    };
}

function normSourceColumn(raw, index) {
    var src = raw || {};
    var type = safeString(src.type || "text").trim().toLowerCase();
    if (type !== "number" && type !== "date")
        type = "text";
    return {
        key: normalizeKey(src.key || ("column_" + String(index + 1))),
        label: safeString(src.label || ("Column " + String(index + 1))).trim(),

}

function sheetList(value) {
    if (Array.isArray(value)) {
        var out = [];
        for (var i = 0; i < value.length; i += 1) {
            var item = String(value[i] === undefined || value[i] === null ? "" : value[i]).trim();
            if (item)
                out.push(item);
        }
